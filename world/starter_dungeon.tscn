[sub_resource type="ProceduralSkyMaterial" id="ProceduralSkyMaterial_sky"]
; Cave darkness but not pure black — the void behind walls should read as
; "dark cave continues" rather than "off the edge of the world".
sky_top_color = Color(0.08, 0.07, 0.09, 1)
sky_horizon_color = Color(0.12, 0.10, 0.09, 1)
ground_bottom_color = Color(0.05, 0.05, 0.06, 1)
ground_horizon_color = Color(0.10, 0.09, 0.08, 1)

[sub_resource type="Sky" id="Sky_env"]
sky_material = SubResource("ProceduralSkyMaterial_sky")

[sub_resource type="Environment" id="Environment_env"]
background_mode = 2
sky = SubResource("Sky_env")
; AMBIENT was 0.3 (near-black). Bumped to 0.7 so floors + walls are lit
; enough to read in shadow — torches/ring-glow become highlights, not the
; only light sources in the scene.
ambient_light_source = 2
ambient_light_color = Color(0.42, 0.38, 0.34, 1)
ambient_light_energy = 0.7
tonemap_mode = 2
; Exponential fog fades distant cells into cave gloom instead of revealing
; the scene edge as a sharp void. Short depth so only off-map reads as fog.
fog_enabled = true
fog_light_color = Color(0.08, 0.06, 0.05, 1)
fog_density = 0.015

[node name="StarterDungeon" type="Node3D"]
script = ExtResource("1_root")
