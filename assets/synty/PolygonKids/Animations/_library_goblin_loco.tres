[gd_resource type="AnimationLibrary" format=3]

; Idle uses BaseLocomotion's upright standing clip — the equivalent GBL idle
; is authored as a deep goblin crouch and reads as "sitting" on the kid.
; Walk / run stay on GoblinLocomotion for the shambly gait.
[ext_resource type="Animation" path="res://assets/synty/BaseLocomotion/Animations/A_Idle_Standing_Masc.tres" id="1_idle"]
[ext_resource type="Animation" path="res://assets/synty/GoblinLocomotion/Animations/A_POLY_GBL_Walk_F_Neut.tres" id="2_walk"]
[ext_resource type="Animation" path="res://assets/synty/GoblinLocomotion/Animations/A_POLY_GBL_Run_F_Neut.tres" id="3_run"]
[ext_resource type="Animation" path="res://assets/synty/BaseLocomotion/Animations/A_InAir_FallLarge_Masc.tres" id="4_attack"]
[ext_resource type="Animation" path="res://assets/synty/BaseLocomotion/Animations/A_MOD_BL_TPose_Neut.tres" id="5_unknown"]

[resource]
_data = {
&"attack": ExtResource("4_attack"),
&"idle": ExtResource("1_idle"),
&"run": ExtResource("3_run"),
&"unknown": ExtResource("5_unknown"),
&"walk": ExtResource("2_walk")
}
